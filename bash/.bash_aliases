
# alias for quit
alias :q='exit'
alias :Q='exit'
alias quit='exit'

# alias for cd
alias cd..='cd ..'
alias up='cd ..'

# some more ls aliases
alias ll='ls -alF'
alias la='ls -A'
alias l='ls -CF'

# Alias for clear
alias cl='clear'
alias clr='clear'

# Python Env
alias actpy="source ~/.local/lib/python/bin/activate"
